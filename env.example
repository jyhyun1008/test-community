# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/fediverse
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=fedi:          # 여러 앱이 Redis 공유할 때 키 충돌 방지

# ─── Auth ───────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string
SESSION_SECRET=change-this-to-another-random-string
BCRYPT_ROUNDS=12

# ─── Object Storage (S3-compatible) ─────────────────────
STORAGE_DRIVER=r2             # r2 | s3 | local
STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=my-fedi-media
STORAGE_PUBLIC_URL=media.yourdomain.com  # CDN 퍼블릭 URL

# ─── Email (선택) ────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ─── Instance (핵심 설정은 config/instance.ts 권장) ──────
INSTANCE_DOMAIN=yourdomain.com   # ActivityPub에서 가장 중요
NODE_ENV=production